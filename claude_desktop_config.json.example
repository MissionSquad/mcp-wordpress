{
  "mcpServers": {
    "wordpress": {
      "command": "npx",
      "args": ["-y", "@missionsquad/mcp-wp"],
      "env": {
        "WORDPRESS_API_URL": "https://wpsite.example.com",
        "WORDPRESS_USERNAME": "username",
        "WORDPRESS_PASSWORD": "application-password",
        "WORDPRESS_SQL_ENDPOINT": "/mcp/v1/query"
      }
    }
  }
}
